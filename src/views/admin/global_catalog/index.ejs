<div class="flex flex-col md:flex-row justify-between items-start md:items-center bg-slate-900 text-white p-6 md:p-8 rounded-3xl mb-8 gap-4">
    <div>
        <h1 class="text-2xl font-bold">Catálogo Global</h1>
        <p class="text-slate-400 text-sm mt-1">Gerencie e modere os produtos do catálogo global</p>
    </div>
    <div class="flex gap-2 w-full md:w-auto overflow-x-auto pb-2 md:pb-0">
        <a href="/admin/global-catalog?status=pendente" class="whitespace-nowrap px-4 py-2 <%= status === 'pendente' || !status ? 'bg-food-orange text-white' : 'bg-slate-800 text-slate-400' %> rounded-lg text-sm font-bold border border-slate-700 hover:bg-orange-600 transition-colors">
            Pendentes
        </a>
        <a href="/admin/global-catalog?status=validado" class="whitespace-nowrap px-4 py-2 <%= status === 'validado' ? 'bg-food-orange text-white' : 'bg-slate-800 text-slate-400' %> rounded-lg text-sm font-bold border border-slate-700 hover:bg-orange-600 transition-colors">
            Validados
        </a>
    </div>
</div>

<div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
    <div class="p-6 border-b border-slate-100 flex gap-4">
        <form class="flex-1 flex gap-2" action="/admin/global-catalog" method="GET">
            <input type="hidden" name="status" value="<%= status %>">
            <input type="text" name="search" value="<%= search %>" placeholder="Buscar por EAN ou Nome..." class="w-full px-4 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-food-orange focus:border-transparent">
            <button type="submit" class="bg-slate-900 text-white px-6 py-2 rounded-lg font-bold text-sm hover:bg-slate-800 transition-colors">Buscar</button>
        </form>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-sm text-left">
            <thead class="bg-slate-50 text-slate-600 font-medium uppercase text-xs">
                <tr>
                    <th class="px-6 py-4">Produto</th>
                    <th class="px-6 py-4">EAN</th>
                    <th class="px-6 py-4">Status</th>
                    <th class="px-6 py-4">Confiança</th>
                    <th class="px-6 py-4">Fontes</th>
                    <th class="px-6 py-4 text-right">Ações</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
<% 
    const statusColors = { 
        'pendente': 'bg-amber-100 text-amber-700 border-amber-200',
        'validado': 'bg-green-100 text-green-700 border-green-200',
        'rejeitado': 'bg-red-100 text-red-700 border-red-200',
        'arquivado': 'bg-slate-100 text-slate-700 border-slate-200'
    };
%>
<% products.forEach(product => { %>
                <tr class="hover:bg-slate-50/50 transition-colors">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-slate-100 flex items-center justify-center overflow-hidden shrink-0">
                                <% if (product.foto_url) { %>
                                    <img src="<%= product.foto_url %>" alt="" class="w-full h-full object-cover">
                                <% } else { %>
                                    <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                                <% } %>
                            </div>
                            <div>
                                <div class="font-medium text-slate-900"><%= product.nome_produto %></div>
                                <div class="text-xs text-slate-500"><%= product.marca || 'Marca desconhecida' %></div>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 font-mono text-slate-600"><%= product.ean %></td>
                    <td class="px-6 py-4">
                        <span class="px-2.5 py-1 rounded-full text-xs font-semibold border <%= statusColors[product.status] || statusColors['arquivado'] %>">
                            <%= product.status.charAt(0).toUpperCase() + product.status.slice(1) %>
                        </span>
                    </td>

                    <td class="px-6 py-4">
                        <div class="flex items-center gap-2">
                            <div class="flex-1 w-16 h-1.5 bg-slate-100 rounded-full overflow-hidden">
                                <div class="h-full <%= product.nivel_confianca > 70 ? 'bg-green-500' : (product.nivel_confianca > 30 ? 'bg-amber-500' : 'bg-red-500') %>" style="width: <%= product.nivel_confianca %>%"></div>
                            </div>
                            <span class="text-xs font-medium text-slate-600"><%= product.nivel_confianca %>%</span>
                        </div>
                    </td>
                    <td class="px-6 py-4 text-slate-600">
                        <%= product.quantidade_fontes %>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <a href="/admin/global-catalog/<%= product.ean %>" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-slate-100 text-slate-600 hover:bg-slate-200 hover:text-slate-900 transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path></svg>
                        </a>
                    </td>
                </tr>
                <% }) %>
                <% if (products.length === 0) { %>
                <tr>
                    <td colspan="6" class="px-6 py-12 text-center text-slate-500">
                        Nenhum produto encontrado.
                    </td>
                </tr>
                <% } %>
            </tbody>
        </table>
    </div>
    
    <% if (totalPages > 1) { %>
    <div class="px-6 py-4 border-t border-slate-100 flex justify-between items-center bg-slate-50">
        <div class="text-xs text-slate-500">
            Mostrando <strong><%= products.length %></strong> de <strong><%= totalItems %></strong> resultados
        </div>
        <div class="flex gap-1">
            <% if (page > 1) { %>
            <a href="/admin/global-catalog?page=<%= page - 1 %>&status=<%= status %>&search=<%= search %>" class="px-3 py-1 bg-white border border-slate-200 rounded text-slate-600 hover:bg-slate-100 text-xs">Anterior</a>
            <% } %>
            <span class="px-3 py-1 bg-slate-900 text-white rounded text-xs"><%= page %></span>
            <% if (page < totalPages) { %>
            <a href="/admin/global-catalog?page=<%= page + 1 %>&status=<%= status %>&search=<%= search %>" class="px-3 py-1 bg-white border border-slate-200 rounded text-slate-600 hover:bg-slate-100 text-xs">Próxima</a>
            <% } %>
        </div>
    </div>
    <% } %>
</div>

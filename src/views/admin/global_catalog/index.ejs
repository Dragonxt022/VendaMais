<section class="mb-8 rounded-[2rem] border border-orange-100 bg-white p-6 shadow-sm md:p-8">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <p class="mb-2 text-xs font-bold uppercase tracking-[0.24em] text-orange-700">Catalogo Global</p>
            <h2 class="text-3xl font-bold text-slate-900">Moderacao e qualidade de dados</h2>
            <p class="mt-3 max-w-2xl text-slate-500">Revise produtos enviados, aprove registros confiaveis e mantenha o catalogo global consistente.</p>
        </div>
        <div class="flex flex-wrap gap-2">
            <a href="/admin/global-catalog?status=pendente" class="rounded-xl px-4 py-2 text-sm font-bold transition-colors <%= status === 'pendente' || !status ? 'bg-food-orange text-white shadow-lg shadow-orange-200/60' : 'border border-slate-200 bg-white text-slate-600 hover:bg-orange-50 hover:text-food-orange' %>">
                Pendentes
            </a>
            <a href="/admin/global-catalog?status=validado" class="rounded-xl px-4 py-2 text-sm font-bold transition-colors <%= status === 'validado' ? 'bg-food-orange text-white shadow-lg shadow-orange-200/60' : 'border border-slate-200 bg-white text-slate-600 hover:bg-orange-50 hover:text-food-orange' %>">
                Validados
            </a>
        </div>
    </div>
</section>

<section class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-6 py-5">
        <form class="flex flex-col gap-3 md:flex-row" action="/admin/global-catalog" method="GET">
            <input type="hidden" name="status" value="<%= status %>">
            <input type="text" name="search" value="<%= search %>" placeholder="Buscar por EAN ou nome do produto" class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm outline-none transition-all focus:border-food-orange focus:ring-2 focus:ring-food-orange/20">
            <button type="submit" class="rounded-xl bg-slate-900 px-5 py-3 text-sm font-bold text-white transition-colors hover:bg-slate-800">Buscar</button>
        </form>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full min-w-[940px] text-left text-sm">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Produto</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-[0.22em] text-slate-400">EAN</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Status</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Confianca</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Fontes</th>
                    <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Acao</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% const statusColors = { 
                    'pendente': 'bg-amber-100 text-amber-700',
                    'validado': 'bg-emerald-100 text-emerald-700',
                    'rejeitado': 'bg-red-100 text-red-700',
                    'arquivado': 'bg-slate-100 text-slate-700'
                }; %>
                <% products.forEach(product => { %>
                    <tr class="transition-colors hover:bg-orange-50/30">
                        <td class="px-6 py-5">
                            <div class="flex items-center gap-3">
                                <div class="flex h-11 w-11 shrink-0 items-center justify-center overflow-hidden rounded-2xl bg-slate-100">
                                    <% if (product.foto_url) { %>
                                        <img src="<%= product.foto_url %>" alt="" class="h-full w-full object-cover">
                                    <% } else { %>
                                        <img class="h-5 w-5 opacity-50" src="/uploads/icon/box-produtos.svg" alt="">
                                    <% } %>
                                </div>
                                <div>
                                    <p class="font-semibold text-slate-900"><%= product.nome_produto %></p>
                                    <p class="text-xs text-slate-500"><%= product.marca || 'Marca nao informada' %></p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-5 font-mono text-xs text-slate-500"><%= product.ean %></td>
                        <td class="px-6 py-5">
                            <span class="rounded-full px-3 py-1 text-xs font-bold <%= statusColors[product.status] || statusColors.arquivado %>">
                                <%= product.status.charAt(0).toUpperCase() + product.status.slice(1) %>
                            </span>
                        </td>
                        <td class="px-6 py-5">
                            <div class="flex items-center gap-3">
                                <div class="h-2 w-24 overflow-hidden rounded-full bg-slate-100">
                                    <div class="h-full <%= product.nivel_confianca > 70 ? 'bg-emerald-500' : (product.nivel_confianca > 30 ? 'bg-amber-500' : 'bg-red-500') %>" style="width: <%= product.nivel_confianca %>%"></div>
                                </div>
                                <span class="text-xs font-semibold text-slate-600"><%= product.nivel_confianca %>%</span>
                            </div>
                        </td>
                        <td class="px-6 py-5 text-slate-600"><%= product.quantidade_fontes %></td>
                        <td class="px-6 py-5 text-right">
                            <a href="/admin/global-catalog/<%= product.ean %>" class="inline-flex items-center justify-center rounded-xl border border-slate-200 px-3 py-2 text-sm font-semibold text-slate-600 transition-colors hover:border-orange-200 hover:bg-orange-50 hover:text-food-orange">
                                Revisar
                            </a>
                        </td>
                    </tr>
                <% }) %>
                <% if (products.length === 0) { %>
                    <tr>
                        <td colspan="6" class="px-6 py-16 text-center text-slate-500">Nenhum produto encontrado para este filtro.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>

    <% if (totalPages > 1) { %>
        <div class="flex flex-col gap-3 border-t border-slate-100 bg-slate-50 px-6 py-4 md:flex-row md:items-center md:justify-between">
            <p class="text-sm text-slate-500">Mostrando <strong><%= products.length %></strong> de <strong><%= totalItems %></strong> resultados</p>
            <div class="flex gap-2">
                <% if (page > 1) { %>
                    <a href="/admin/global-catalog?page=<%= page - 1 %>&status=<%= status %>&search=<%= search %>" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-600 transition-colors hover:bg-orange-50 hover:text-food-orange">Anterior</a>
                <% } %>
                <span class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-bold text-white"><%= page %></span>
                <% if (page < totalPages) { %>
                    <a href="/admin/global-catalog?page=<%= page + 1 %>&status=<%= status %>&search=<%= search %>" class="rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-600 transition-colors hover:bg-orange-50 hover:text-food-orange">Proxima</a>
                <% } %>
            </div>
        </div>
    <% } %>
</section>

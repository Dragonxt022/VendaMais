<section class="mb-8 rounded-[2rem] border border-orange-100 bg-white p-6 shadow-sm md:p-8">
    <div class="flex flex-col gap-5 lg:flex-row lg:items-center lg:justify-between">
        <div>
            <p class="mb-2 text-xs font-bold uppercase tracking-[0.24em] text-orange-700">Empresas</p>
            <h2 class="text-3xl font-bold text-slate-900">Gestao de empresas da plataforma</h2>
            <p class="mt-3 max-w-2xl text-slate-500">Acompanhe clientes, planos ativos e o estado operacional de cada conta cadastrada.</p>
        </div>
        <a href="/admin/companies/new" class="inline-flex items-center justify-center gap-2 rounded-2xl bg-food-orange px-5 py-3 text-sm font-bold text-white shadow-lg shadow-orange-200/60 transition-colors hover:bg-orange-600">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Nova Empresa
        </a>
    </div>
</section>

<section class="mb-6 grid grid-cols-1 gap-4 md:grid-cols-3">
    <article class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Total</p>
        <p class="mt-3 text-3xl font-bold text-slate-900"><%= companies.length %></p>
    </article>
    <article class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Ativas</p>
        <p class="mt-3 text-3xl font-bold text-emerald-600"><%= companies.filter(company => company.status === 'active').length %></p>
    </article>
    <article class="rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Plano Pro</p>
        <p class="mt-3 text-3xl font-bold text-orange-700"><%= companies.filter(company => company.plan === 'pro').length %></p>
    </article>
</section>

<section class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-sm">
    <div class="flex items-center justify-between border-b border-slate-100 px-6 py-5">
        <div>
            <h3 class="text-lg font-bold text-slate-900">Base de empresas</h3>
            <p class="text-sm text-slate-500">Visao consolidada das contas cadastradas</p>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="w-full min-w-[860px] text-left">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Empresa</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-[0.22em] text-slate-400">CNPJ</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Plano</th>
                    <th class="px-6 py-4 text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Status</th>
                    <th class="px-6 py-4 text-right text-xs font-bold uppercase tracking-[0.22em] text-slate-400">Acoes</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                <% if (companies.length > 0) { %>
                    <% companies.forEach(company => { %>
                        <tr class="transition-colors hover:bg-orange-50/40">
                            <td class="px-6 py-5">
                                <div class="flex items-center gap-3">
                                    <div class="flex h-11 w-11 items-center justify-center overflow-hidden rounded-2xl bg-orange-100 text-sm font-bold text-orange-800">
                                        <% if (company.logo_url) { %>
                                            <img src="<%= company.logo_url %>" alt="Logo" class="h-full w-full object-cover">
                                        <% } else { %>
                                            <%= company.name.charAt(0).toUpperCase() %>
                                        <% } %>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-900"><%= company.name %></p>
                                        <p class="text-sm text-slate-500">Conta empresarial</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-5 font-mono text-sm text-slate-500"><%= company.cnpj %></td>
                            <td class="px-6 py-5">
                                <span class="rounded-full px-3 py-1 text-xs font-bold <%= company.plan === 'pro' ? 'bg-orange-100 text-orange-700' : 'bg-slate-100 text-slate-700' %>">
                                    <%= company.plan.toUpperCase() %>
                                </span>
                            </td>
                            <td class="px-6 py-5">
                                <span class="rounded-full px-3 py-1 text-xs font-bold <%= company.status === 'active' ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700' %>">
                                    <%= company.status === 'active' ? 'ATIVA' : 'INATIVA' %>
                                </span>
                            </td>
                            <td class="px-6 py-5">
                                <div class="flex justify-end gap-2">
                                    <a href="/admin/companies/<%= company.id %>/edit" class="rounded-xl border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-600 transition-colors hover:border-orange-200 hover:bg-orange-50 hover:text-food-orange">
                                        Editar
                                    </a>
                                    <form action="/admin/companies/<%= company.id %>/toggle" method="POST">
                                        <button type="submit" class="rounded-xl border px-4 py-2 text-sm font-semibold transition-colors <%= company.status === 'active' ? 'border-red-200 text-red-600 hover:bg-red-50' : 'border-emerald-200 text-emerald-700 hover:bg-emerald-50' %>">
                                            <%= company.status === 'active' ? 'Desativar' : 'Ativar' %>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="5" class="px-6 py-16 text-center text-slate-500">Nenhuma empresa cadastrada no momento.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</section>

<div class="mx-auto">
    <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900">Meu Perfil</h1>
        <p class="text-slate-500 mt-1">
            Gerencie suas informações pessoais e foto de perfil de forma rápida e segura.
        </p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
        <div class="mb-6 p-4 bg-red-50 border border-red-100 text-red-600 rounded-2xl flex items-center gap-3">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="font-medium"><%= error %></span>
        </div>
    <% } %>

    <form
        action="/app/profile"
        method="POST"
        enctype="multipart/form-data"
    >
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">
            <!-- Coluna da Foto -->
            <div class="flex flex-col items-center lg:items-start gap-4 rounded-2xl border border-slate-200 shadow-sm p-4">
                <div id="avatarImageUpload" data-image-upload="avatar" class="w-40 h-40"></div>
                <p class="text-xs text-slate-400 font-medium italic">Clique na imagem para alterar</p>
            </div>

            <!-- Coluna do Formulário -->
            <div class="lg:col-span-2">
                <div class="bg-white p-8 md:p-10 rounded-[2.5rem] border border-slate-100 shadow-sm">
                    <div class="space-y-8">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div class="md:col-span-2">
                                <%- include('../partials/ui/input', {
                                    label: 'Nome Completo',
                                    name: 'name',
                                    value: user.name,
                                    placeholder: 'Ex: João Silva',
                                    required: true
                                }) %>
                            </div>

                            <div>
                                <%- include('../partials/ui/input', {
                                    label: 'E-mail',
                                    name: 'email',
                                    value: user.email,
                                    placeholder: 'seu@email.com',
                                    required: true
                                }) %>
                            </div>

                            <div>
                                <%- include('../partials/ui/input', {
                                    label: 'CPF / CNPJ',
                                    name: 'cpf_cnpj',
                                    value: user.cpf_cnpj || '',
                                    placeholder: '000.000.000-00'
                                }) %>
                            </div>
                        </div>

                        <div class="pt-8 border-t border-slate-50 flex justify-end">
                            <%- include('../partials/ui/button', {
                                text: 'Salvar Alterações',
                                type: 'submit',
                                variant: 'primary',
                                extraClasses: 'px-10 py-4 text-base'
                            }) %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize avatar upload with existing image
        const avatarUpload = document.getElementById('avatarImageUpload');
        if (avatarUpload) {
            const imageUploadInstance = new ImageUpload('#avatarImageUpload', {
                fallbackImage: '/images/placeholders/avatar-placeholder.svg'
            });
            
            // Set existing avatar if available
            <% if (user.avatar) { %>
                imageUploadInstance.setImage('<%= user.avatar %>');
            <% } %>
        }
    });
</script>

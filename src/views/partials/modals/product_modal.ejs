<!-- Modal Novo Produto -->
<div id="productModal" class="hidden fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-end justify-end p-0">
    <div class="bg-white w-full max-w-lg h-full shadow-2xl overflow-hidden transform translate-x-full transition-transform duration-300 ease-in-out" id="productModalContent">
        <div class="flex flex-col h-full">
            <div class="p-6 border-b border-slate-100 flex justify-between items-center flex-shrink-0">
                <h2 class="text-xl font-bold text-slate-900">Cadastrar Produto</h2>
                <button onclick="toggleModal('productModal')" class="text-slate-400 hover:text-slate-600 text-2xl leading-none">×</button>
            </div>
            <form action="/app/products" method="POST" enctype="multipart/form-data" class="flex-1 overflow-y-auto p-6 grid grid-cols-2 gap-4" id="productModalForm">
            <div class="col-span-2">
                <div class="flex gap-6 items-start">
                    <label id="productImageUpload" data-image-upload="product" class="group w-32 h-32 flex-shrink-0 relative overflow-hidden rounded-xl border-2 border-dashed border-slate-200 hover:border-food-orange transition-all duration-200 cursor-pointer bg-slate-50 hover:bg-slate-100 flex items-center justify-center"></label>
                    <div class="flex-1 space-y-4">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">EAN (Código de Barras)</label>
                            <div class="flex gap-2">
                                <input type="text" name="ean" id="product_ean" maxlength="13" class="flex-1 px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-food-orange focus:ring-2 focus:ring-food-orange/10 transition-all font-mono" placeholder="789...">
                                <button type="button" onclick="searchGlobalCatalog()" id="btnSearchEan" class="px-3 py-2 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-colors" title="Pesquisar no Catálogo Global">
                                    <img src="/uploads/icon/search.svg" alt="Pesquisar" class="w-6 h-6">
                                </button>
                            </div>
                        </div>
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Nome do Produto</label>
                            <input type="text" name="name" id="product_name" required class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-food-orange focus:ring-2 focus:ring-food-orange/10 transition-all" placeholder="Ex: Coca-Cola 2L">
                        </div>
                    </div>
                </div>
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">SKU / Ref</label>
                <input type="text" name="sku" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-food-orange transition-all">
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Preço de Venda</label>
                <div class="relative">
                    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-sm">R$</span>
                    <input type="text" name="price" id="product_price" required class="js-currency-input w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-food-orange transition-all input-price" placeholder="0,00">
                </div>
            </div>
            <div class="col-span-2 flex items-center gap-3 p-4 bg-slate-50 rounded-xl border border-slate-100">
                <div class="relative inline-block w-12 h-6 transition duration-200 ease-in-out">
                    <input type="checkbox" name="manage_stock" id="manage_stock" class="peer absolute w-0 h-0 opacity-0" checked onchange="toggleStockFields(this)">
                    <label for="manage_stock" class="block overflow-hidden h-6 rounded-full bg-slate-300 cursor-pointer peer-checked:bg-food-orange transition-colors"></label>
                    <span class="absolute left-1 top-1 bg-white w-4 h-4 rounded-full transition-transform peer-checked:translate-x-6"></span>
                </div>
                <label for="manage_stock" class="text-sm font-semibold text-slate-700 cursor-pointer select-none">Gerenciar Estoque deste item?</label>
            </div>

            <div id="stockFields" class="contents">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Preço de Custo</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 text-sm">R$</span>
                        <input type="text" name="cost" id="product_cost" class="js-currency-input w-full pl-10 pr-4 py-2 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-food-orange transition-all input-price" placeholder="0,00">
                    </div>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Qtd. Inicial</label>
                    <input type="number" name="initial_stock" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-food-orange transition-all">
                </div>
                <div class="col-span-2">
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Estoque Mínimo</label>
                    <input type="number" name="min_stock" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-food-orange transition-all">
                </div>
            </div>
            <div>
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Categoria</label>
                <div class="flex gap-2">
                    <select id="product_category_id" name="category_id" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-food-orange transition-all appearance-none cursor-pointer">
                        <option value="">Sem Categoria</option>
                        <% if (typeof categories !== 'undefined') { %>
                            <% categories.forEach(c => { %>
                                <option value="<%= c.id %>"><%= c.name %></option>
                            <% }) %>
                        <% } %>
                    </select>
                    <button type="button" onclick="toggleModal('quickCategoryModal')" class="px-3 py-2 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-colors" title="Nova Categoria">+</button>
                </div>
            </div>
            <div class="col-span-2">
                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">Fornecedor Principal</label>
                <div class="flex gap-2">
                    <select id="product_supplier_id" name="supplier_id" class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-xl outline-none focus:border-food-orange transition-all appearance-none cursor-pointer">
                        <option value="">Sem Fornecedor</option>
                        <% if (typeof suppliers !== 'undefined') { %>
                            <% suppliers.forEach(s => { %>
                                <option value="<%= s.id %>"><%= s.name %></option>
                            <% }) %>
                        <% } %>
                    </select>
                    <button type="button" onclick="toggleModal('quickSupplierModal')" class="px-3 py-2 bg-white border border-slate-200 text-slate-600 rounded-xl hover:bg-slate-50 transition-colors" title="Novo Fornecedor">+</button>
                </div>
            </div>
            <div class="col-span-2 pt-4">
                <button type="submit" class="w-full bg-food-orange text-white py-3 rounded-xl font-bold hover:bg-orange-600 shadow-lg shadow-orange-500/20 transition-all">Salvar Produto</button>
            </div>
            </form>
        </div>
    </div>
</div>

<style>
/* Modal Slide-in Animation */
#productModal.show {
    display: flex !important;
}

#productModal.show #productModalContent {
    transform: translateX(0);
}

#productModal:not(.show) #productModalContent {
    transform: translateX(100%);
}

/* Custom scrollbar for modal */
#productModalForm::-webkit-scrollbar {
    width: 6px;
}

#productModalForm::-webkit-scrollbar-track {
    background: #f1f5f9;
}

#productModalForm::-webkit-scrollbar-thumb {
    background: #cbd5e1;
    border-radius: 3px;
}

#productModalForm::-webkit-scrollbar-thumb:hover {
    background: #94a3b8;
}

/* Mobile responsiveness */
@media (max-width: 640px) {
    #productModalContent {
        max-width: 100%;
        width: 100%;
    }
}
</style>
